version: '3.8'

services:
  app:
    build: .
    ports:
      - "8000:8000"
    environment:
      - NODE_ENV=production
{% if framework == 'flask' %}
      - FLASK_APP=app.py
{% endif %}
    restart: unless-stopped
{% if framework == 'flask' or framework == 'fastapi' %}
  db:
    image: postgres:15
    environment:
      POSTGRES_DB: app_db
      POSTGRES_USER: user
      POSTGRES_PASSWORD: password
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"

volumes:
  postgres_data:
{% endif %}
