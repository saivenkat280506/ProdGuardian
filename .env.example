# ProdGuardian environment variables (optional overrides)
#
# Preferred setup: copy this file to .env for local overrides, OR configure
# ~/.prodguardian.toml via the TUI (Settings) or by hand. Disk config is loaded
# first; these env vars override specific fields at runtime.
#
# Never commit .env or ~/.prodguardian.toml — they may contain API keys.

# LLM API key (Groq, OpenAI, Anthropic, etc. — depends on model prefix)
PRODGUARDIAN_API_KEY=

# Mono-scan model (used when scan_mode is mono)
# Examples: groq/llama-3.1-8b-instant, openai/gpt-4o-mini, ollama/llama3.2:3b
PRODGUARDIAN_MODEL=gpt-3.5-turbo

# Custom API base URL (leave empty for provider defaults; set for Ollama proxy)
PRODGUARDIAN_BASE_URL=

# Scan mode: mono | hybrid
PRODGUARDIAN_SCAN_MODE=mono

# Hybrid mode only — analyzer model (deep code review)
PRODGUARDIAN_ANALYZER_MODEL=groq/llama-3.3-70b-versatile

# Hybrid mode only — reporter model (formats findings)
PRODGUARDIAN_REPORTER_MODEL=groq/llama-3.1-8b-instant